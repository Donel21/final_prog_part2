<Window x:Class="final_prog_part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#9999FF">

    <Grid>

        <!-- WELCOME GRID -->
        <Grid x:Name="WelcomeGrid" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="cyberbot.jpg" Width="600" Height="400" Margin="0,0,0,20"/>
                <TextBlock Text="CYBERSECURITY CHAT BOT" FontSize="28" FontWeight="Bold" 
                          Foreground="White" HorizontalAlignment="Center" Margin="0,10"/>
                <TextBlock Text="Stay Safe • Stay Secure • Stay Smart" FontSize="16" 
                          Foreground="Lavender" HorizontalAlignment="Center"/>
                <Button Content="START" Width="250" Height="55" Margin="0,40,0,0" 
                       FontSize="18" FontWeight="Bold" Background="#8B5CF6" 
                       Foreground="White" BorderBrush="#C084FC" Click="Start_Click"/>
            </StackPanel>
        </Grid>

        <!-- NAME GRID -->
        <Grid x:Name="NameGrid" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Enter Your Name" FontSize="24" Foreground="White" 
                          HorizontalAlignment="Center"/>
                <TextBox x:Name="NameTextBox" Width="300" Height="45" Margin="0,20" FontSize="16"/>
                <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="14" 
                          HorizontalAlignment="Center"/>
                <Button Content="CONTINUE" Width="250" Height="50" Background="#8B5CF6" 
                       BorderBrush="#C084FC" Foreground="White" FontWeight="Bold" 
                       Click="Submit_Click"/>
            </StackPanel>
        </Grid>

        <!-- CHAT GRID -->
        <Grid x:Name="ChatGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- QUICK ACTION BUTTONS -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,10,20,5" 
                       HorizontalAlignment="Center">
                <Button Content="📋 Show Tasks" Click="QuickAction_Click" 
                       Background="#8B5CF6" Foreground="White" Margin="0,0,10,0" 
                       Padding="15,8" BorderBrush="#C084FC"/>
                <Button Content="🎮 Start Quiz" Click="QuickAction_Click" 
                       Background="#8B5CF6" Foreground="White" Margin="0,0,10,0" 
                       Padding="15,8" BorderBrush="#C084FC"/>
                <Button Content="📊 Show Log" Click="QuickAction_Click" 
                       Background="#8B5CF6" Foreground="White" Margin="0,0,10,0" 
                       Padding="15,8" BorderBrush="#C084FC"/>
                <Button Content="❓ Help" Click="QuickAction_Click" 
                       Background="#8B5CF6" Foreground="White" Padding="15,8" 
                       BorderBrush="#C084FC"/>
            </StackPanel>

            <!-- CHAT AREA -->
            <Border Grid.Row="1" Margin="20" CornerRadius="10" Background="#9333AE">
                <TextBox x:Name="ChatListBox" Background="#C4B5FD" Foreground="Black" 
                        FontSize="15" IsReadOnly="True" TextWrapping="Wrap" 
                        VerticalScrollBarVisibility="Auto"/>
            </Border>

            <!-- INPUT AREA -->
            <Grid Grid.Row="2" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="MessageTextBox" Grid.Column="0" Height="50" FontSize="16" 
                        VerticalContentAlignment="Center" Margin="0,0,10,0" 
                        KeyDown="MessageTextBox_KeyDown"/>
                <Button Content="SEND" Grid.Column="1" Height="50" FontSize="16" 
                       FontWeight="Bold" Background="#8B5CF6" BorderBrush="#C084FC" 
                       Foreground="White" Click="Send_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>